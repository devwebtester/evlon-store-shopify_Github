{% schema %}
{
  "name": "Premium Hero Real Estate",
  "settings": [
    { "type": "image_picker", "id": "bg", "label": "Background Image" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shaping future through excellence" },
    { "type": "textarea", "id": "subtext", "label": "Subtext" },
    { "type": "textarea", "id": "left_text", "label": "Left Text" },
    { "type": "text", "id": "btn_text", "label": "Button Text", "default": "View Services" },
    { "type": "url", "id": "btn_link", "label": "Button Link" }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "image_picker", "id": "icon_img", "label": "Icon Image" },
        { "type": "range", "id": "icon_size", "min": 20, "max": 80, "step": 2, "default": 40, "label": "Icon Size" },
        { "type": "text", "id": "title", "label": "Title", "default": "High quality products" },
        { "type": "textarea", "id": "desc", "label": "Description" }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [{ "name": "Premium Hero Real Estate" }]
}
{% endschema %}

<section class="sp-hero">
<div class="sp-bg" style="background-image:url({{ section.settings.bg | img_url: 'master' }});">    
    <div class="sp-overlay"></div>

    <div class="sp-container">

      <!-- CENTER -->
      <div class="sp-center">
        <h1>{{ section.settings.heading }}</h1>
        <p>{{ section.settings.subtext }}</p>
      </div>

      <div class="sp-line"></div>

      <!-- ROW -->
      <div class="sp-row">
        <div class="sp-left2">
          <h3>{{ section.settings.left_text }}</h3>
        </div>

        <div>
          <a href="" class="sp-btn2">
  <span class="text">View Services</span>

  <span class="btn-icon-wrap">
    <span class="btn-icon">
      ➚
    </span>
    <span class="btn-icon-hover">
      ➚
    </span>
  </span>
</a>
        </div>
      </div>

      <!-- CARDS -->
      <div class="sp-cards">
        {% for block in section.blocks %}
          <div class="sp-card">
            
            {% if block.settings.icon_img %}
             <div class="sp-icon-wrap">
  <img 
    src="{{ block.settings.icon_img | image_url: width: 100 }}" 
    style="width:{{ block.settings.icon_size }}px"
  >
</div>
            {% endif %}

            <h4>{{ block.settings.title }}</h4>
            <p>{{ block.settings.desc }}</p>
          </div>
        {% endfor %}
      </div>

    </div>
  </div>
</section>

<style>
.sp-hero { color:#fff; font-family:Poppins; }

.sp-bg {
  background-size:cover;
  background-position:center;
  padding:120px 20px 0;
  position:relative;
}

.sp-overlay {
  position:absolute;
  inset:0;
  background:linear-gradient(to bottom, rgb(0 0 0 / 20%), rgba(0, 0, 0, .3));
}

.sp-container {     
  position: relative;
    max-width: 1300px;
    margin: auto;
    padding: 100px 0 0;
}

/* CENTER */
.sp-center { 
  text-align:center; 
  margin-bottom:40px;
  align-items: center;
    justify-content: center;
    display: flex;
    flex-direction: column; 
}

.sp-center h1 { 
  font-size:90px; 
  font-weight:700;
  letter-spacing: -2px;
      margin: 0;
}
.sp-center p { 
    opacity: .85;
margin:10px 0 80px 0;
    font-size: 22px;
    font-weight: 600;
    width: 63%;
    color: #c5c5c5; 
}


/* LINE */
.sp-line { height:1px; background:rgba(255,255,255,.2);}

/* ROW */
.sp-row {
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin: 60px 0 60px 0;
}

.sp-left2 { max-width:600px; }
.sp-left2 h3 { 
     font-size: 36px;
    line-height: 35px;
}

.sp-btn2 {
  display: inline-flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
  padding: 7px 10px 7px 25px;
  background: #fff;
  border-radius: 50px;
  text-decoration: none;
  font-weight: 600;
  color: #000;
  transition: 0.3s;
}

/* ICON CIRCLE */
.btn-icon-wrap {
  position: relative;
  width: 50px;
  height: 50px;
  background: #e4ed64;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

/* BOTH ICONS */
.btn-icon,
.btn-icon-hover {
  position: absolute;
  font-size: 18px;
  transition: 0.45s cubic-bezier(0.47, 0.05, 0.5, 0.94);
}

/* DEFAULT ICON */
.btn-icon {
  transform: translate(0, 0);
}

/* HOVER ICON (start bottom-left) */
.btn-icon-hover {
  transform: translate(-20px, 20px);
  opacity: 0;
}

/* HOVER ANIMATION */
.sp-btn2:hover .btn-icon {
  transform: translate(20px, -20px);
  opacity: 0;
}

.sp-btn2:hover .btn-icon-hover {
  transform: translate(0, 0);
  opacity: 1;
}

/* BUTTON HOVER */
.sp-btn2:hover {
  transform: translateY(-2px);
}

/* CARDS */
.sp-cards {
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:30px;
  position: relative;
  z-index:1;
}

/* CARD STYLE (Elementor Glass Effect) */
.sp-card {
padding: 40px 40px 50px;
    border-radius: 20px;
    background: #00000000;
    -webkit-backdrop-filter: blur(25px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    box-shadow: -6px 0px 11px #80808029;
    transition: all 0.4s ease;
    backdrop-filter: blur(39px);
}
.sp-card  h4 { 
  font-size:26px; 
      margin: 0;
    padding-bottom: 5px;
  
}
.sp-card p{
font-size: 17px;
    color: #cdcdcd;
    line-height: 26px;}
/* ICON IMAGE */
.sp-icon-wrap img {
  margin-bottom: 20px;
  filter: brightness(0) saturate(100%) invert(75%) sepia(70%) saturate(500%) hue-rotate(20deg) brightness(90%);
  transition: 0.3s;
  width: 48px !important;
}


/* WRAPPER */
.sp-icon-wrap {
  position: relative;
  display: inline-block;
  margin-bottom: 20px;
  padding-bottom: 15px;
      width: 100%;
}

/* GRAY LINE */
.sp-icon-wrap::before {
  content: "";
  position: absolute;
  left: 0;
  bottom: 0;
  width: 100%;
  height: 1px;
    background: #FFFFFF26;
}

/* GREEN ANIMATION */
.sp-icon-wrap::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: 0;
  width: 100%;
  height: 1px;
  background: #e4ed64;

  transform: scaleX(0);
  transform-origin: 0 0;
  transition: 0.45s cubic-bezier(0.47, 0.05, 0.5, 0.94);
}

/* HOVER */
.sp-card:hover .sp-icon-wrap::after {
  transform: scaleX(1);
  transition: 0.45s cubic-bezier(0.47, 0.05, 0.5, 0.94) 0.2s;
}
/* RESPONSIVE */
@media(max-width:768px){
  .sp-center h1 { font-size:60px; }
  .sp-center p { 
    margin: 10px 0 10px 0 !important;
    font-size: 22px;
    width: 100%;
}
.sp-container {
    padding: 70px 0 0;
}
.sp-left2 h3 {
    font-size: 34px;
    width: 87%;
}
.sp-left2 {
    max-width: 509px;
}
.sp-row {
    margin: 45px 0 45px 0;
}
.sp-cards{
  gap:10px;
}
}

@media(max-width:600px){
  .sp-cards { grid-template-columns:1fr; }
}

@media(max-width:1024px){
  .sp-center p {
 margin: 10px 0 30px 0;
  }
}
@media(max-width:430px){
  .sp-center h1 { font-size:52px; }
  .sp-container {
        padding: 40px 0 0;
    }
    .sp-row {
    display: grid;
    align-items: center;
    gap: 20px;
    margin: 55px 0 50px 0;
    text-align: center;
    }
    .sp-left2 h3 {
        font-size: 32px;
        width: 100%;
    }
    .sp-icon-wrap {
    padding-bottom: 4px;
    }
    .sp-card {
    padding: 25px 30px 40px;
    }
    
}
</style>