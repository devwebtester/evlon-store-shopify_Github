<section class="seasonly-cta">

    <div class="cta-bg" 
        style="background-image: url({{ section.settings.bg_image | image_url: width: 2000 }});">
    </div>

    <div class="cta-overlay"
        style="background: rgba(0,0,0, {{ section.settings.overlay_opacity | divided_by: 100.0 }});">
    </div>

    <div class="cta-content">
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>

        <h2>{{ section.settings.heading }}</h2>

        <p class="subtext">
            {{ section.settings.subtext }}
        </p>

        {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link }}" class="cta-btn">
            {{ section.settings.button_label }}
        </a>
        {% endif %}
    </div>
</section>


{% schema %}
{
  "name": "CTA Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 45
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "READY WHEN YOU ARE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Book Your Treatment Now."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Real results, real touch, real ingredients. Reserve your slot at the Seasonly studio. We can’t wait to see your skin."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "BOOK YOUR TREATMENT"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Seasonly CTA"
    }
  ]
}
{% endschema %}


<style>
    .seasonly-cta {
        position: relative;
        width: 100%;
        height: 650px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0 20px;
        overflow: hidden;
    }

    .seasonly-cta .cta-bg {
        position: absolute;
        inset: 0;
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
    }

    .seasonly-cta .cta-overlay {
        position: absolute;
        inset: 0;
    }

    .seasonly-cta .cta-content {
        position: relative;
        z-index: 2;
        {% comment %} max-width: 800px; {% endcomment %}
        text-align: center;
    }

    .seasonly-cta .eyebrow {
        font-size: 18px;
        text-transform: uppercase;
        color: #ffffff;
        margin-bottom: 16px;
    }

    .seasonly-cta h2 {
        font-size: 48px;
        line-height: 58px;
        font-weight: 600;
        color: #fff;
        margin-bottom: 16px;
        margin-top: 0;
    }

    .seasonly-cta .subtext {
        font-size: 18px;
        line-height: 28px;
        color: #ffffff;
        {% comment %} max-width: 640px; {% endcomment %}
        margin: 0 auto 36px;
    }

    .seasonly-cta .cta-btn {
        display: inline-block;
        background: #fff;
        color: #000000;
        font-size: 18px;
        line-height: 26px;
        text-transform: uppercase;
        padding: 12px 36px;
        text-decoration: none;
        border-radius: 2px;
        transition: all 0.25s ease;
    }

    .seasonly-cta .cta-btn:hover {
        background: #000000;
        color: #ffffff;
    }

    @media (max-width: 1024px) {
        .seasonly-cta {
            height: 460px;
        }

        .seasonly-cta h2 {
            font-size: 36px;
            line-height: 46px;
        }
    }

    @media (max-width: 767px) {
        .seasonly-cta {
            height: 420px;
        }

        .seasonly-cta h2 {
            font-size: 30px;
            line-height: 40px;
        }

        .seasonly-cta .subtext {
            max-width: 600px;
        }

        .seasonly-cta .cta-btn {
            padding: 12px 24px;
        }
    }
</style>