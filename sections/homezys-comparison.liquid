<section class="comparison-section-{{ section.id }} comparison-wrapper">
  <div class="grid-container-comparison">
    
    <div class="content-side">
      <h2 class="heading">{{ section.settings.heading }}</h2>
      <p class="subtext">{{ section.settings.subtext }}</p>
      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link }}" class="custom-btn">{{ section.settings.button_label }}</a>
      {% endif %}
    </div>

    <div class="slider-side">
      <div class="comparison-container" id="Comparison-{{ section.id }}">
        <div class="image-after">
          {% if section.settings.image_after != blank %}
             <img src="{{ section.settings.image_after | image_url: width: 1000 }}" alt="After" loading="lazy">
          {% else %}
             {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>

        <div class="image-before" id="BeforeImage-{{ section.id }}">
          {% if section.settings.image_before != blank %}
             <img src="{{ section.settings.image_before | image_url: width: 1000 }}" alt="Before" loading="lazy">
          {% else %}
             {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>

        <input type="range" min="0" max="100" value="50" class="slider-input" id="Slider-{{ section.id }}">
        <div class="slider-button" id="Handle-{{ section.id }}">
           <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8L22 12L18 16M6 8L2 12L6 16"/></svg>
        </div>
      </div>
    </div>

  </div>
</section>

<style>


  .comparison-wrapper {
     background: #E9F0F2; 
     overflow: hidden; 
    }
  .grid-container-comparison { 
    display: flex; 
    align-items: center;
    gap: 50px; flex-wrap: wrap;
 }
  .content-side {
     flex: 1; 
     min-width: 300px;
     }
  .slider-side {
     flex: 1.2;
      min-width: 300px;
     }
  
.content-side .heading {
     font-family: serif; 
     font-size: 3rem; 
     color: #1a1a1a;
      margin-bottom: 20px;
       line-height: 1.2;
           font-weight: 500;
     }
 .content-side .subtext {
     font-size: 18px;
      color: #444;
       margin-bottom: 30px; 
       line-height: 1.5; 
    }
 .content-side .custom-btn { 
    display: inline-block;
    padding: 15px 40px;
     background: #2d4a3e;
      color: white; 
    text-decoration: none; 
    border-radius: 4px; 
    transition: 0.3s; 
  }
 .content-side .custom-btn:hover {
     background: #1e332a;
      transform: translateY(-2px);
     }

  /* Slider Core CSS */
  .comparison-container { 
    position: relative;
     width: 100%; 
     aspect-ratio: 1/1;
      border-radius: 12px;
       overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
     }
  .image-after, .image-before {
     position: absolute; 
     top: 0; 
     left: 0; 
     width: 100%;
      height: 100%; 
    }
  .image-after img, .image-before img {
     width: 100%;
      height: 100%;
       object-fit: cover;
        display: block;
     }
  .image-before {
     z-index: 2;
     clip-path: inset(0 50% 0 0); 
    }
  
  .slider-input {
    position: absolute;
     -webkit-appearance: none;
      appearance: none;
    width: 100%;
     height: 100%;
      background: transparent;
       z-index: 10;
        cursor: ew-resize;
         margin: 0; top:0; left:0;
  }
  .slider-button {
    position: absolute;
     top: 50%;
      left: 50%; 
      transform: translate(-50%, -50%);
    width: 40px;
     height: 40px;
      background: #fff;
       border-radius: 50%;
        z-index: 5;
    display: flex;
     align-items: center;
      justify-content: center;
       box-shadow: 0 0 15px rgba(0,0,0,0.2);
        pointer-events: none;
  }
  .slider-button svg {
     width: 20px;
      color: #2d4a3e; 
    }
  .slider-button::before, .slider-button::after {
    content: ''; 
    position: absolute;
     width: 2px;
      height: 100vh;
       background: #fff;
        left: 50%;
         transform: translateX(-50%);
  }
  .slider-button::before { 
    bottom: 40px;
 }
  .slider-button::after {
     top: 40px; 
    }

  }


  @media (max-width: 768px) {
    .heading {
         font-size: 2.2rem;
         }
    .grid-container-comparison {
         gap: 30px;
         }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const slider = document.getElementById('Slider-{{ section.id }}');
    const beforeImage = document.getElementById('BeforeImage-{{ section.id }}');
    const handle = document.getElementById('Handle-{{ section.id }}');

    slider.addEventListener('input', (e) => {
      let value = e.target.value;
      beforeImage.style.clipPath = `inset(0 ${100 - value}% 0 0)`;
      handle.style.left = `${value}%`;
    });
  });
</script>

{% schema %}
{
  "name": "Before After Comparison",
  "settings": [
    { 
        "type": "image_picker",
         "id": "image_before",
          "label": "Before Image (Left Side)" 
        },
    { 
        "type": "image_picker",
         "id": "image_after",
          "label": "After Image (Right Side)"
         },
    { 
        "type": "text", 
        "id": "heading", 
        "label": "Heading", 
        "default": "The Essence of Unforgettable Presence"
     },
    {
         "type": "textarea",
          "id": "subtext", 
          "label": "Subheading",
           "default": "The Art of Scent — Individual Notes become an Unforgettable Journey"
         },
    { 
        "type": "text",
         "id": "button_label",
          "label": "Button Label",
           "default": "Discover Now"
         },
    { 
        "type": "url",
         "id": "button_link", 
         "label": "Button Link" 
        },
    {
         "type": "range",
          "id": "padding_top",
           "min": 0, "max": 100,
            "step": 4, "unit": "px",
             "label": "Top Padding",
              "default": 40 
            },
    { 
        "type": "range", 
        "id": "padding_bottom",
         "min": 0,
          "max": 100, 
          "step": 4, 
          "unit": "px", 
          "label": "Bottom Padding",
           "default": 40 
        }
  ],
  "presets": [
    {
         "name": "Before After Comparison"
         }
  ]
}
{% endschema %}