{% schema %}
{
  "name": "Homezys FAQ",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "image_picker",
      "id": "faq_image",
      "label": "Right Image"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How long does shipping take?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Shipping usually takes 5–7 business days depending on your location."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Homezys FAQ",
      "blocks": [
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" }
      ]
    }
  ]
}
{% endschema %}

<section class="hz-faq">
  <div class="hz-container">

    <!-- LEFT ACCORDION -->
    <div class="hz-left">
      <h2 class="hz-title">{{ section.settings.heading }}</h2>

      <div class="hz-accordion">
        {% for block in section.blocks %}
          <div class="hz-item">
            <button class="hz-question">
              {{ block.settings.question }}
              <span class="hz-icon">+</span>
            </button>
            <div class="hz-answer">
              <p>{{ block.settings.answer }}</p>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

    <!-- RIGHT IMAGE -->
    <div class="hz-right">
      {% if section.settings.faq_image %}
        <img src="{{ section.settings.faq_image | img_url: 'master' }}" alt="FAQ">
      {% endif %}
    </div>

  </div>
</section>

<style>
.hz-faq {
  padding: 80px 20px;
  background: #fff;
}

.hz-container {
  max-width: 1200px;
  margin: auto;
  display: flex;
  gap: 60px;
  align-items: center;
}

/* LEFT */
.hz-left {
  flex: 1;
}

.hz-title {
  font-size: 36px;
  margin-bottom: 25px;
}

/* ACCORDION */
.hz-accordion {
  display: flex;
  flex-direction: column;
  gap: 15px;
}

.hz-item {
  background: #f7f9f8;
  border-radius: 12px;
  padding: 18px 20px;
  border: 1px solid #e5e5e5;
  transition: 0.3s ease;
}

.hz-item.active {
  background: #fff;
  border-color: #4A9B6F;
  box-shadow: 0 5px 20px rgba(0,0,0,0.05);
}

.hz-question {
  width: 100%;
  background: none;
  border: none;
  font-size: 16px;
  font-weight: 600;
  text-align: left;
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.hz-icon {
  width: 26px;
  height: 26px;
  border-radius: 50%;
  background: #4A9B6F;
  color: #fff;
  font-size: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: 0.3s;
}

.hz-item.active .hz-icon {
  transform: rotate(45deg);
}

.hz-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.4s ease;
}

.hz-answer p {
  margin-top: 12px;
  color: #555;
  font-size: 14px;
  line-height: 1.6;
}

/* RIGHT IMAGE */
.hz-right {
  flex: 1;
}

.hz-right img {
  width: 100%;
  border-radius: 16px;
}

/* MOBILE */
@media (max-width: 768px) {
  .hz-container {
    flex-direction: column;
  }

  .hz-title {
    text-align: center;
  }
}
</style>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const items = document.querySelectorAll(".hz-item");

  // FIRST OPEN
  if (items.length > 0) {
    items[0].classList.add("active");
    const firstAnswer = items[0].querySelector(".hz-answer");
    firstAnswer.style.maxHeight = firstAnswer.scrollHeight + "px";
  }

  items.forEach((item) => {
    const btn = item.querySelector(".hz-question");
    const answer = item.querySelector(".hz-answer");

    btn.addEventListener("click", () => {
      items.forEach((el) => {
        if (el !== item) {
          el.classList.remove("active");
          el.querySelector(".hz-answer").style.maxHeight = null;
        }
      });

      item.classList.toggle("active");

      if (item.classList.contains("active")) {
        answer.style.maxHeight = answer.scrollHeight + "px";
      } else {
        answer.style.maxHeight = null;
      }
    });
  });
});
</script>