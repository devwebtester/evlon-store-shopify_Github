
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

{% schema %}
{
  "name": "Category Slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore Categories"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Category",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Select Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Slider"
    }
  ]
}
{% endschema %}

<section class="sxpro-sec">
  <div class="sxpro-wrap">

    <h2 class="sxpro-title">{{ section.settings.heading }}</h2>

    <!-- SWIPER -->
    <div class="swiper sxpro-swiper">
      <div class="swiper-wrapper">

        {% for block in section.blocks %}
        {% assign col = block.settings.collection %}
        {% if col != blank %}

        <div class="swiper-slide">

          <a href="{{ col.url }}" class="sxpro-card">

            <div class="sxpro-img">
              <img src="{{ col.image | image_url: width: 800 }}" alt="">
            </div>

            <div class="sxpro-overlay"></div>

            <div class="sxpro-content">
              <h3>{{ col.title }}</h3>
            </div>

          </a>

        </div>

        {% endif %}
        {% endfor %}

      </div>
    </div>

  </div>
</section>


<style>

/* SECTION */
.sxpro-sec{
  padding:80px 0;
  background:#f5f5f5;
  width:100%;
}

/* CONTAINER */
.sxpro-wrap{
  max-width:1600px;
  margin:auto;
  padding:0 20px;
}

/* TITLE */
.sxpro-title{
  font-size:42px;
  margin-bottom:40px;
}

.sxpro-swiper{
  width:100%;
}

.swiper-slide{
  height:auto;
}

/* REMOVE flex slider styles */
.sxpro-slider{
  display:none;
}


/* CARD */
.sxpro-card{
  position:relative;
  width:100%; /* 🔥 IMPORTANT */
  height:420px;
  border-radius:24px;
  overflow:hidden;
  display:block;
}
.swiper-slide{
  height:auto;
}
/* IMAGE */
.sxpro-img{
  position:absolute;
  inset:0;
}
.sxpro-img img{
  width:100%;
  height:100%;
  object-fit:cover;
  transition:0.6s ease;
}

/* OVERLAY */
.sxpro-overlay{
  position:absolute;
  inset:0;

  background:linear-gradient(
    to top,
    rgba(0,0,0,0.85) 0%,
    rgba(0,0,0,0.5) 40%,
    rgba(255,255,255,0.2) 100%
  );

  opacity:0; /* 🔥 IMPORTANT FIX */
  transition:0.4s ease;
  z-index:1;
}

/* CONTENT */
.sxpro-content{
  position:absolute;
  bottom:20px;
  left:20px;
  right:20px;
  z-index:2;
  transform:translateY(40px);
  opacity:0;
  transition:0.5s ease;
}
.sxpro-content h3{
 display:inline-block;
  color:#fff;
  padding:10px 10px;
  font-size:18px;
  font-weight:600;
}

/* HOVER EFFECT */
.sxpro-card:hover img{
  transform:scale(1.1);
}
.sxpro-card:hover .sxpro-overlay{
  opacity:1;
}
.sxpro-card:hover .sxpro-content{
  transform:translateY(0);
  opacity:1;
}
@media(max-width:1024px){
.sxpro-card {
    position: relative;
    width: 100%;
    height: 330px;
}
}
@media(max-width:768px){
  .sxpro-slider{
    gap:16px;
  }
  .sxpro-title{
    font-size:30px;
  }
}

@media(max-width:425px){
  .sxpro-slider{
    gap:12px;
  }
  .sxpro-title{
    font-size:24px;
  }
}

</style>
<script>
document.addEventListener("DOMContentLoaded", function(){

  new Swiper(".sxpro-swiper", {
    slidesPerView: 5,
    spaceBetween: 24,
    grabCursor: true,
    speed: 600,

    breakpoints: {
      0: {
        slidesPerView: 1
      },
      425: {
        slidesPerView: 1
      },
      768: {
        slidesPerView: 3
      },
      1024: {
        slidesPerView: 4
      },
      1400: {
        slidesPerView: 5
      }
    }
  });

});
</script>