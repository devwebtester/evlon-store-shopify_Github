{% schema %}
{
  "name": "Hero Footer Advanced Pro",
  "settings": [
    { "type": "image_picker", "id": "bg_image", "label": "Background Image" },

    { "type": "text", "id": "title", "default": "Your dream home awaits", "label": "Title" },
    { "type": "textarea", "id": "subtitle", "default": "Whether you're exploring our homes or envisioning something custom, we're here to bring your dream to life.", "label": "Subtitle" },

    { "type": "text", "id": "button_text", "default": "Get your free quote", "label": "Button Text" },
    { "type": "url", "id": "button_link", "label": "Button Link" },

    { "type": "text", "id": "big_text", "default": "spaciaz", "label": "Background Big Text" },

    { "type": "image_picker", "id": "logo", "label": "Footer Logo" },
    { "type": "textarea", "id": "desc", "label": "Footer Description" },

    { "type": "link_list", "id": "menu1", "label": "Left Menu" },
    { "type": "link_list", "id": "menu2", "label": "Right Menu" },

    { "type": "text", "id": "phone", "default": "+(084) 123 - 456 88", "label": "Phone" },
    { "type": "text", "id": "email", "default": "spaciaz@example.com", "label": "Email" }
  ],

  "blocks": [
    {
      "type": "social",
      "name": "Social",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "Icon" },
        { "type": "text", "id": "name", "label": "Name" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],

  "presets": [
    { "name": "Hero Footer Advanced Pro" }
  ]
}
{% endschema %}

<style>
.section-hero {
  position: relative;
  min-height: 120vh;
  background: url({{ section.settings.bg_image | image_url: width: 2000 }}) center/cover no-repeat;

  background-attachment: fixed; /* ⭐ PARALLAX EFFECT */
  background-position: center;
  background-size: cover;

  display: grid;
  align-items: center;
  justify-content: center;
  text-align: center;

  color: #fff;
  overflow: hidden;
  padding-bottom: 30px;

}

/* overlay */
.section-hero::before{
  content:"";
  position:absolute;
  inset:0;
  background:#0000009e;
}

/* TOP WHITE CURVE */
.section-hero::after{
  content:"";
  position:absolute;
  top:-60px;
  left:0;
  width:100%;
  height:120px;
  background:#f5f5f5;
  border-radius:0 0 60px 60px;
  z-index:1;
}

/* BIG BACK TEXT */
.big-text {
  position: absolute;
  bottom: 25%;
  width: 100%;
  text-align: center;

  font-size: clamp(80px, 20vw, 376px);
  font-weight: 700;
  text-transform: lowercase;
  white-space: nowrap;

  /* GRADIENT TEXT */
      background: linear-gradient(to bottom, rgb(255 255 255) 0%, rgb(255 255 255 / 41%) 40%, rgb(0 0 0) 100%);

  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;

  /* fallback for non-webkit */
  color: transparent;

  z-index: 1;
  pointer-events: none;
}

/* HERO CONTENT */
.hero-content{
  position:relative;
  z-index:2;
  max-width:700px;
  margin:auto;
  align-items: center;
    justify-content: center;
    display: flex;
    flex-direction: column;

}
.hero-content h1{
    font-size:70px;
margin: 140px 0px 12px 0px;
line-height:71px;
}
.hero-content p{
margin:0;
font-size: 18px;
width: 80%;
}

.hero-btn{
margin-top: 25px;
    width: 160px;
    font-size: 20px;
    height: 160px;
    border: 1px solid #FFFFFF1A;
    font-weight: 700;
    line-height: 25px;
    border-radius: 50%;
    background: #182836;
    display: flex;
    padding: 30px;
    align-items: center;
    justify-content: center;
    color: #fff;
    text-decoration: none;
}

/* FOOTER FLOAT */
.footer-box{
  margin-top:130px;
  position:relative;
  z-index:3;
}

.footer-inner{
  width:100%;
  max-width:1730px;
  background:#ffffff;
  border-radius:40px;
padding-top: 60px;
    padding-bottom: 0px;
    padding-left: 30px;
    padding-right: 30px;
    margin-top:-30px;
}
.menu-main {
    display: flex;
    flex-direction: row;
    gap: 40px;
}
/* GRID */
.footer-grid{
  display:grid;
grid-template-columns: 1.4fr 1.4fr 1.6fr;
  gap:40px;
  padding: 0px 190px;
}

/* CENTER LOGO */
.logo-box{
  text-align:left;
  display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: space-between;
}
.logo-box img{
  max-width:174px;
  display:block;
}
.logo-box p{
  margin-top:15px;
  color:#8a8a8a;
  font-size:18px;
}

/* MENUS */
{% comment %} .menu-divider{
  border-left:1px solid #ddd;
  padding-left:20px;
} {% endcomment %}
.menu-left {
  border-left: 1px solid #ddd;
}

.menu-right {
  border-right: 1px solid #ddd;
  padding-right: 20px;
}
.menu-right ul {
    padding-left: 0;
}
.footer-inner ul{list-style:none;
}
.footer-inner li{
    margin-bottom: 17px;
    text-align: left;
    font-size: 16px;
    color: #000000;
}
li a{
        color: #000000;
        font-weight:600;
}
/* CONTACT */
.contact{
  font-size:36px;
  font-weight:bold;
  color: #000;
  text-align:left;
}
.contact a{
  display:block;
  margin-top:10px;
border-bottom: 1px solid #cddc39;
    width: fit-content;
    color: #000;}
.contact-main {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: space-between;
}
/* SOCIAL */
.social{
  margin-top:20px;
  display:flex;
}
.social-item{
  display:flex;
  align-items:center;
  margin-bottom:10px;
}
.social img{
  width:18px;
}
.social-item a {
    font-weight: 600;
    color: #8a8a8a;
}
/* BOTTOM */
.bottom{
text-align: center;
    width: 1300px;
    margin: auto;
    font-size: 18px;
    margin-top: 60px;
    border-top: 1px solid #ddd;
    padding-top: 40px;
    padding-bottom: 40px;
    color: #8a8a8a;
}
.bottom span {
    color: #000;
    font-weight: bold;
}
/* RESPONSIVE */

@media (max-width: 1024px) {
    .section-hero{
    padding-right: 30px;
    padding-left: 30px;
}
  .hero-content h1 {
    font-size: 48px;
    line-height: 54px;
    margin: 100px 0 10px;
  }
.footer-inner ul {
    list-style: none;
    padding: 0;
    margin: 0;
}
.menu-main {
    gap: 15px;
}
.menu-left {
    border:none;
}
.menu-right{
  border:none;
}
  .footer-grid {
    grid-template-columns: 1fr 1fr;
    padding: 0 10px;
    gap: 30px;
  }
.contact {
    font-size: 32px;
}
  .big-text {
    font-size: 214px;
    bottom: 52%;
  }

  .bottom {
    width: 100%;
  }
}
@media (max-width: 768px) {
.hero-content{
      max-width: 600px;
}
  .hero-content h1 {
    font-size: 56px;
    line-height: 42px;
    margin: 110px 0 10px;
  }

  .hero-content p {
    font-size: 18px;
    width: 95%;
  }

    .hero-btn {
        width: 150px;
        height: 150px;
        font-size: 20px;
        padding: 28px;
    }

  .big-text {
    font-size: 153px;
    bottom: 51%;
  }

  .footer-grid {
    grid-template-columns: 1fr 1fr;
    padding: 0 20px;
    gap:18px;
  }
  .logo-box p {
    margin-top: 34px !important;
  }
  .contact-main { 
    justify-content: start;
}
.logo-box {
    justify-content: flex-start;
}
  .footer-inner {
    padding: 40px 15px 0;
    border-radius: 25px;
    margin-top:-76px;
  }
.contact {
    font-size: 30px;
}
  .menu-left,
  .menu-right {
    border: none;
    padding: 0;
  }

  .bottom {
    padding: 30px;
  }
}
@media (max-width: 480px) {

  .hero-content h1 {
    font-size: 42px;
  }
      .logo-box {
        justify-content: center;
        text-align: center;
        align-items: center;
    }
    .hero-content {
        max-width: 400px;
    }
  .big-text {
    font-size: 85px;
    bottom: 66%;
  }
  .footer-grid {
        grid-template-columns: 1fr;
        gap:30px;
  }
      .contact-main {
        justify-content: center;
        text-align: center;
        align-items: center;
        gap:15px;
    }
    .contact a {
    display: block;
    text-align: center;
    width: 100%;
    }
    .menu-main {
    display: flex;
    flex-direction: row;
    gap: 32px;
   padding: 30px 20px;
    width: 100%;
    margin: auto;
    border-top: 1px solid #dbdbdb;
    border-bottom: 1px solid #dbdbdb;
}
.section-hero {
  padding-right: 15px;
  padding-left: 15px;
}
.contact {
        font-size: 28px;
    }
.footer-inner{
  margin-top: -52px;
   max-width: 395px;
   padding: 30px 0 0;
}
  .hero-btn {
    display: none;
  }
  .footer-inner ul {
    list-style: none;
    padding: 0;
}
    .bottom {
        width: 94%;
        margin-top: 20px;
        padding: 40px 0;
    }
}
@media (max-width: 375px) {
    .menu-main {
              padding: 30px 0px;
              gap:25px;
    }
  }
  @media (max-width: 320px) {
  .footer-grid {
        display: block;
        gap: 30px;
        overflow: hidden;
  }
   .hero-content {
        max-width: 300px;
      }
      .footer-inner {
        max-width: 285px;
      }
          .contact {
        font-size: 22px;
    }
    .bottom{
      font-size: 14px;
    }
    .social {
    margin-top: 20px;
    display: flex;
    flex-wrap: wrap;
    line-height: 0px;
}
    .big-text {
        font-size: 75px;
        bottom: 66%;
    }
}

</style>

<!-- HERO -->
<div class="section-hero">

  <div class="hero-content">
    <h1>{{ section.settings.title }}</h1>
    <p>{{ section.settings.subtitle }}</p>

    <a href="{{ section.settings.button_link }}" class="hero-btn">
      {{ section.settings.button_text }}
    </a>
  </div>

  <div class="big-text">
    {{ section.settings.big_text }}
  </div>
<div class="footer-box">
  <div class="footer-inner">

    <div class="footer-grid">

      <!-- LOGO CENTER -->
      <div class="logo-box">
        {% if section.settings.logo %}
          <img src="{{ section.settings.logo | image_url }}">
        {% endif %}
        <p>{{ section.settings.desc }}</p>
      </div>

      <!-- MENU 1 -->
      <!-- MENU 1 -->
      <div class="menu-main">
<div class="menu-left">
  <ul>
    {% for link in linklists[section.settings.menu1].links %}
      <li><a href="{{ link.url }}">{{ link.title }}</a></li>
    {% endfor %}
  </ul>
</div>

<!-- MENU 2 -->
<div class="menu-right">
  <ul>
    {% for link in linklists[section.settings.menu2].links %}
      <li><a href="{{ link.url }}">{{ link.title }}</a></li>
    {% endfor %}
  </ul>
</div>
</div>
      <!-- CONTACT -->
      <div class="contact-main">
        <div class="contact">
             <a href="">
          {{ section.settings.phone }}
             </a>
          <a href="mailto:{{ section.settings.email }}">
            {{ section.settings.email }}
          </a>
        </div>

        <div class="social">
          {% for block in section.blocks %}
            <div class="social-item">
              {% if block.settings.icon %}
                <img src="{{ block.settings.icon | image_url }}">
              {% endif %}
              <a href="{{ block.settings.link }}">
                {{ block.settings.name }}
              </a>
            </div>
          {% endfor %}
        </div>
      </div>

    </div>

    <div class="bottom">
      © {{ 'now' | date: "%Y" }} <span>Spaciaz. </span>All Rights Reserved.
    </div>

  </div>
</div>
</div>

