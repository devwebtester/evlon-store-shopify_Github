{% schema %}
{
  "name": "XSP Sticky Projects Final",
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Project Slide",
      "settings": [
        { "type": "text", "id": "tag", "label": "Tag", "default": "PROJECTS" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Innovative designs, lasting impressions" },
        { "type": "text", "id": "location", "label": "Location", "default": "Bay Shore, NY" },
        { "type": "text", "id": "title", "label": "Title", "default": "Apartment Building" },
        { "type": "image_picker", "id": "image", "label": "Image" }
      ]
    }
  ],
  "presets": [{ "name": "XSP Sticky Projects Final" }]
}
{% endschema %}

{%- assign total = section.blocks.size -%}

<section class="xsp-sec" style="height: calc(100vh * {{ total | plus: 1 }});">
  <div class="xsp-wrap">
    <!-- LEFT -->
    <div class="xsp-left">
      {% for block in section.blocks %}
        {% if forloop.first %}
          <div class="xsp-fixed-top">
            <div class="xsp-marquee-wrap">
              <div class="xsp-marquee">
                <div class="xsp-marquee-track">
                  {% for i in (1..12) %}
                    <span>{{ block.settings.tag }}</span>
                    <span class="dot">•</span>
                  {% endfor %}
                </div>
              </div>
            </div>
            <h2 class="xsp-heading">{{ block.settings.heading }}</h2>
          </div>
        {% endif %}
      {% endfor %}

      {% for block in section.blocks %}
        <div class="xsp-content" data-index="{{ forloop.index0 }}">
          <div class="xsp-content-inner">
            <div class="xsp-number">0{{ forloop.index }}</div>

            <div class="xsp-info">
              <p class="xsp-location">
                <span class="xsp-loc-icon">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                    <path d="M12 2C8 2 5 5 5 9C5 14 12 22 12 22C12 22 19 14 19 9C19 5 16 2 12 2Z" stroke="#d4ff3f" stroke-width="2"/>
                    <circle cx="12" cy="9" r="2" fill="#d4ff3f"/>
                  </svg>
                </span>
                {{ block.settings.location }}
              </p>
              <div class="xsp-divider"></div>
              <h3 class="xsp-title">{{ block.settings.title }}</h3>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

    <!-- RIGHT -->
    <div class="xsp-right">
      {% for block in section.blocks %}
        <div class="xsp-img-panel" data-index="{{ forloop.index0 }}">
          {% if block.settings.image %}
            <img src="{{ block.settings.image | image_url: width: 1600 }}" class="xsp-img">
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .xsp-sec {
    position: relative;
  }

  .xsp-wrap {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    overflow: hidden;
  }

  /* LEFT */
  .xsp-left {
    width: 50%;
    background: #0c0c0b;
    color: #fff;
    position: relative;
    overflow: hidden;
  }

  .xsp-fixed-top {
    position: absolute;
    top: 60px;
    left: 320px;
    right: 64px;
    z-index: 5;
    transition: opacity 0.4s ease;
  }

  .xsp-tag {
    border: 1px solid #d4ff3f;
    padding: 6px 14px;
    border-radius: 30px;
    font-size: 12px;
  }
  /* MARQUEE */
  .xsp-marquee-wrap {
    display: inline-block;
    border: 1px solid #d4ff3f;
    border-radius: 30px;
    padding: 6px 14px;
    overflow: hidden;
        width: 22%;

  }

  .xsp-marquee {
    overflow: hidden;
    white-space: nowrap;
  }

  .xsp-marquee-track {
    display: flex;
    gap: 15px;
    animation: xspScroll 2s linear infinite;
    font-size: 12px;
    font-weight: 600;
    color: #fff;
  }

  .xsp-marquee-track .dot {
    color: #d4ff3f;
  }

  @keyframes xspScroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-100%); }
  }
  .xsp-heading {
    font-size: 70px;
    margin-top: 30px;
    color:white;
  }

  /* CONTENT */
  .xsp-content {
    position: absolute;
    bottom: 0;
    width: 100%;
    transform: translateY(100%);
    transition: transform 1s cubic-bezier(0.76, 0, 0.24, 1);
    z-index: 2;
  }
  .xsp-fixed-top.xsp-hide {
    opacity: 0;
    pointer-events: none;
  }
  .xsp-content.xsp-active,
  .xsp-content.xsp-done {
    transform: translateY(0%);
  }

  .xsp-content-inner {
    height: 100vh;
    padding: 80px 20px 20px 320px;
    display: flex;
    align-items: flex-end;
    gap: 50px;
    background: #0c0c0b;
  }

  .xsp-number {
      font-size: 100px;
    font-weight: 700;
    line-height: 1;

    color: transparent; /* 🔥 no fill */
    -webkit-text-stroke: 1px rgba(255,255,255,0.15); /* outline */

    opacity: 1;
  }

  .xsp-location {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 16px;
      color: #ffffff;
      margin-bottom: 20px;
      font-weight: 700;
  }
  .xsp-loc-icon {
    display: flex;
    align-items: center;
  }

  /* DIVIDER LINE */
  .xsp-divider {
    width: 100%;
    height: 1px;
    background: rgb(255, 255, 255);
    margin: 12px 0 15px;
  }

  /* TITLE */
  .xsp-title {
    font-size: 36px;
    font-weight: 600;
    color: #fff;
  }

  /* RIGHT */
  .xsp-right {
    width: 50%;
    position: relative;
    overflow: hidden;
  }

  .xsp-img-panel {
    position: absolute;
    inset: 0;
    clip-path: inset(100% 0 0 0);
    transition: clip-path 1s cubic-bezier(0.76, 0, 0.24, 1);
  }

  .xsp-img-panel:first-child {
    clip-path: inset(0 0 0 0);
  }

  .xsp-img-panel.xsp-active,
  .xsp-img-panel.xsp-done {
    clip-path: inset(0 0 0 0);
  }

  .xsp-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media(max-width:1440px){

    .xsp-fixed-top{
      left: 120px;
      top: 40px;
    }

    .xsp-heading{
      font-size: 48px;
    }

    .xsp-content-inner{
      padding: 60px 20px 20px 120px;
      gap: 30px;
    }

    .xsp-number{
      font-size: 70px;
    }

    .xsp-title{
      font-size: 28px;
    }

    .xsp-marquee-wrap{
      width: 40%;
    }
  }
  @media(max-width:1024px){
      .xsp-content-inner{
      padding: 60px 20px 20px 20px;
      gap: 30px;
    }
        .xsp-fixed-top {
          left: 20px;
          top: 40px;
      }
      .xsp-heading {
          font-size: 40px;
      }
          .xsp-title {
          font-size: 25px;
      }
  }
  @media(max-width:430px){

    .xsp-wrap{
      flex-direction:row !important;
    }

    .xsp-left{
      width:55%;
    }

    .xsp-right{
      width:45%;
    }

       .xsp-fixed-top {
          left: 20px;
          top: 40px;
          right: 0;
      }

    .xsp-heading{
      font-size:22px;
              line-height: 32px;
          margin: 20px 0;
    }

  .xsp-content-inner {
          padding: 20px 0px 20px 20px;
          gap: 16px;
          display: flex;
          flex-direction: column;
          justify-content: end;
          text-align: left;
          align-items: flex-start;
  }

    .xsp-number{
      font-size:60px;
    }

    .xsp-location{
      font-size:16px;
    }

    .xsp-title{
      font-size:28px;
    }
      .xsp-marquee-wrap {
          width: 60%;
      }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const contents = document.querySelectorAll('.xsp-content');
    const images = document.querySelectorAll('.xsp-img-panel');
    const section = document.querySelector('.xsp-sec');
    const heading = document.querySelector('.xsp-fixed-top');

    const total = contents.length;

    function updateScroll() {
      const rect = section.getBoundingClientRect();
      const scrollTop = window.scrollY + rect.top;
      const sectionHeight = section.offsetHeight;

      let progress = (window.scrollY - scrollTop) / sectionHeight;
      progress = Math.max(0, Math.min(1, progress));

      const index = Math.floor(progress * total);

      /* 🔥 MAIN LOGIC */
      if (index === 0) {
        heading.classList.remove('xsp-hide');
      } else {
        heading.classList.add('xsp-hide');
      }

      contents.forEach((el, i) => {
        el.classList.remove('xsp-active', 'xsp-done');

        if (i < index) el.classList.add('xsp-done');
        else if (i === index) el.classList.add('xsp-active');
      });

      images.forEach((el, i) => {
        el.classList.remove('xsp-active', 'xsp-done');

        if (i < index) el.classList.add('xsp-done');
        else if (i === index) el.classList.add('xsp-active');
      });
    }

    window.addEventListener('scroll', updateScroll);
    updateScroll();
  });
</script>
