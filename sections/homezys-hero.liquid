{% schema %}
{
  "name": "Homezys Hero Banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Upgrade Your Home Effortlessly"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Sub Heading",
      "default": "Smart solutions for modern living. Simple, stylish, and practical."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image"
    }
  ],
  "presets": [
    {
      "name": "Homezys Hero Banner"
    }
  ]
}
{% endschema %}

<section class="homezys-hero">
  <div class="hero-container">
    
    <!-- LEFT CONTENT -->
    <div class="hero-content">
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.subheading }}</p>

      <a href="{{ section.settings.button_link }}" class="hero-btn">
        {{ section.settings.button_text }}
      </a>

      <div class="hero-badges">
        <span>✔ Premium Quality</span>
        <span>✔ Free Shipping</span>
        <span>✔ Easy Returns</span>
      </div>
    </div>

    <!-- RIGHT IMAGE -->
    <div class="hero-image">
      {% if section.settings.hero_image %}
        <img src="{{ section.settings.hero_image | img_url: 'master' }}" alt="hero">
      {% endif %}
    </div>

  </div>
</section>

<style>
.homezys-hero {
  padding: 80px 20px;
  background: linear-gradient(135deg, #f5f7fa, #eef1f5);
  overflow: hidden;
}

.hero-container {
  max-width: 1200px;
  margin: auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 40px;
}

.hero-content {
  flex: 1;
}

.hero-content h1 {
  font-size: 48px;
  font-weight: 700;
  line-height: 1.2;
  margin-bottom: 20px;
  color: #111;
}

.hero-content p {
  font-size: 18px;
  color: #555;
  margin-bottom: 30px;
}

.hero-btn {
  display: inline-block;
  padding: 14px 32px;
  background: #111;
  color: #fff;
  text-decoration: none;
  border-radius: 30px;
  transition: 0.3s ease;
}

.hero-btn:hover {
  background: #444;
  transform: translateY(-2px);
}

.hero-badges {
  margin-top: 25px;
  display: flex;
  gap: 20px;
  flex-wrap: wrap;
}

.hero-badges span {
  font-size: 14px;
  color: #333;
}

.hero-image {
  flex: 1;
  position: relative;
}

.hero-image img {
  width: 100%;
  border-radius: 20px;
  transition: 0.5s ease;
}

/* subtle floating effect */
.hero-image:hover img {
  transform: scale(1.05);
}

/* Responsive */
@media (max-width: 768px) {
  .hero-container {
    flex-direction: column;
    text-align: center;
  }

  .hero-content h1 {
    font-size: 32px;
  }

  .hero-badges {
    justify-content: center;
  }
}
</style>