{% schema %}
{
  "name": "Studio Locations",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Visit Our Studios"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Sub Text",
      "default": "Experience personalized skin consultations and professional treatments at our carefully curated locations"
    }
  ],
  "blocks": [
    {
      "type": "studio",
      "name": "Studio Card",
      "settings": [
        { "type": "text", "id": "title", "label": "Studio Name" },
        { "type": "textarea", "id": "address", "label": "Address" },
        { "type": "textarea", "id": "timing", "label": "Timing" },
        { "type": "text", "id": "phone", "label": "Phone Number" },
        { "type": "text", "id": "button_text", "label": "Button Text", "default": "BOOK MY TREATMENT" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Studio Locations"
    }
  ]
}
{% endschema %}

<section class="studio-sec" style="background-image:url({{ section.settings.bg_image | image_url: width: 2000 }})">

  <div class="studio-overlay"></div>

  <div class="studio-container">

    <!-- HEADER -->
    <div class="studio-header">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.subtext }}</p>
    </div>

    <!-- CARDS -->
    <div class="studio-grid">
      {% for block in section.blocks %}
        <div class="studio-card">
          
          <h3>{{ block.settings.title }}</h3>

          <p class="studio-info">📍 {{ block.settings.address }}</p>

          <p class="studio-info">⏰ {{ block.settings.timing }}</p>

          <p class="studio-info">📞 {{ block.settings.phone }}</p>

          <a href="#" class="studio-btn">
            {{ block.settings.button_text }}
          </a>

        </div>
      {% endfor %}
    </div>

  </div>

</section>

<style>

/* SECTION */
.studio-sec{
  position:relative;
  padding:100px 20px;
  background-size:cover;
  background-position:center;
  color:#fff;
}

/* OVERLAY */
.studio-overlay{
  position:absolute;
  inset:0;
  background:rgba(0,0,0,0.5);
}

/* CONTAINER */
.studio-container{
  position:relative;
  max-width:1200px;
  margin:auto;
}

/* HEADER */
.studio-header{
  margin-bottom:40px;
}

.studio-header h2{
  font-size:36px;
  margin-bottom:10px;
}

.studio-header p{
  color:#ddd;
  max-width:600px;
}

/* GRID */
.studio-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:20px;
}

/* CARD */
.studio-card{
  background:#fff;
  color:#000;
  padding:25px;
  border-radius:6px;
  transition:0.3s;
}

.studio-card:hover{
  transform:translateY(-5px);
}

/* TEXT */
.studio-card h3{
  font-size:18px;
  margin-bottom:15px;
}

.studio-info{
  font-size:14px;
  margin-bottom:10px;
  color:#555;
}

/* BUTTON */
.studio-btn{
  display:block;
  margin-top:15px;
  text-align:center;
  padding:10px;
  border:1px solid #ddd;
  font-size:13px;
  text-decoration:none;
  color:#000;
  transition:0.3s;
}

.studio-btn:hover{
  background:#000;
  color:#fff;
}

/* RESPONSIVE */
@media(max-width:1024px){
  .studio-grid{
    grid-template-columns:repeat(2,1fr);
  }
}

@media(max-width:600px){
  .studio-grid{
    grid-template-columns:1fr;
  }

  .studio-header h2{
    font-size:26px;
  }
}

</style>