{% schema %}
{
  "name": "Testimonial Advanced",
  "settings": [
    {
      "type": "image_picker",
      "id": "center_image",
      "label": "Top Circle Image"
    },
    {
      "type": "text",
      "id": "circle_text",
      "label": "Circle Text",
      "default": "WHAT PEOPLE SAYS • WHAT PEOPLE SAYS •"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote" },
        { "type": "text", "id": "name", "label": "Name" },
        { "type": "text", "id": "designation", "label": "Designation" }
      ]
    }
  ],
  "presets": [
    { "name": "Testimonial Advanced" }
  ]
}
{% endschema %}

<section class="ts-adv">

  <!-- TOP CIRCLE -->
  <div class="ts-circle-wrap">
    <div class="ts-circle">

      {% if section.settings.center_image %}
        <img src="{{ section.settings.center_image | image_url: width: 200 }}">
      {% endif %}
      <svg class="ts-rotate-text" viewBox="0 0 200 200">
  <defs>
    <path id="circlePath" d="M 100,100 m -80,0 a 80,80 0 1,1 160,0 a 80,80 0 1,1 -160,0"/>
  </defs>

  <text>
    <textPath href="#circlePath">
      {{ section.settings.circle_text }}
    </textPath>
  </text>
</svg>

    </div>
  </div>

  <!-- SLIDER -->
  <div class="ts-container">
    
    <div class="ts-slider" id="tsSlider">
      {% for block in section.blocks %}
        <div class="ts-slide">
          <p class="ts-quote">"{{ block.settings.quote }}"</p>
          <h4>{{ block.settings.name }}</h4>
          <span>{{ block.settings.designation }}</span>
        </div>
      {% endfor %}
    </div>

    <!-- ARROWS -->
    <button class="ts-arrow ts-prev">&#8249;</button>
    <button class="ts-arrow ts-next">&#8250;</button>

  </div>

</section>

<style>

/* SECTION BACKGROUND (GRADIENT + CURVE) */
.ts-adv{
  padding:140px 20px 0;
  position:relative;
  text-align:center;
       background-color: transparent;
    background-image: linear-gradient(180deg, #f6f3ec 0%, #F6F3EC00 100%);
}



/* TOP CIRCLE */
.ts-circle-wrap{
  position:absolute;
  top:-75px;
  left:50%;
  transform:translateX(-50%);
  z-index:3;
}
.ts-circle-wrap::before{
  content:"";
  position:absolute;
  width: 331px;
  height: 344px;
  top:64%;
  left:50%;
  transform:translate(-50%, -50%);
  
  background-image:url('https://cdn.shopify.com/s/files/1/0676/0736/3839/files/svgviewer-png-output_6.png?v=1774949602');
  background-size:contain;
  background-repeat:no-repeat;
  background-position:center;

  z-index:1;
}
.ts-circle-wrap::after{
    content: "";
    position: absolute;
    width: 100%;
    height: 60%;
    left: 47%;
    top: 50%;
    transform: translate(-50%, -50%);
    background-image: url(https://cdn.shopify.com/s/files/1/0676/0736/3839/files/text.png?v=1774950225);
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
    z-index: 999;
}
/* make circle above background */
.ts-circle{
  position:relative;
  z-index:2;
}
.ts-circle{
  width: 200px;
    height: 200px;
    position: relative;
    border-radius: 50%;
    background: #fff;
    padding: 30px;
}

.ts-circle img{
  width:100%;
  height:100%;
  border-radius:50%;
  object-fit:cover;
}

/* QUOTE ICON */
.ts-quote-icon{
  position:absolute;
  bottom:15px;
  right:20px;
  font-size:40px;
  color:#fff;
  background:#000;
  width:45px;
  height:45px;
  border-radius:50%;
  display:flex;
  align-items:center;
  justify-content:center;
}

.ts-rotate-text{
  position:absolute;
  top:-10px;
  left:0px;
  width:220px;
  height:220px;
  animation:rotateText 12s linear infinite;
}

.ts-rotate-text text{
      font-size: 14px;
    font-weight: 600;
  fill:#000;
  text-transform:uppercase;
      letter-spacing: 0px;
      word-spacing:3px;
}

@keyframes rotateText{
  from{ transform:rotate(0deg); }
  to{ transform:rotate(360deg); }
}

/* CONTAINER */
.ts-container{
  max-width:1300px;
  margin:0 auto;
  position:relative;
  z-index:2;
  overflow:hidden;
}

/* SLIDER */
.ts-slider{
  display:flex;
  transition:transform 0.5s ease;
}

.ts-slide{
  min-width:100%;
  flex-shrink:0;
  padding:130px 20px;
}

/* TEXT */
.ts-quote{
  font-size:48px;
  font-weight:600;
  line-height:1.125em;
  max-width:1000px;
  margin:0 auto 90px;
  letter-spacing:-2px;
  color:#000000;
}

.ts-slide h4{
  font-size:20px;
  margin-bottom:27px;
  width:fit-content;
  margin:auto;
  padding:0 0 5px;
  position:relative;
    color:#000000;
}

.ts-slide h4:before{
  content:"";
  width:106px;
  height:2px;
  background:#d4ff3f;
  position:absolute;
  bottom:-1px;
  left:50%;
  transform:translateX(-50%);
}

.ts-slide span{
  color:#777;
  font-size:16px;
}

/* ARROWS */
.ts-arrow{
  position:absolute;
  top:50%;
  transform:translateY(-50%);
  width:60px;
  height:60px;
  border-radius:50%;
  border:none;
  cursor:pointer;
  font-size:22px;
  transition:0.3s;
  background:#f3f3f3;
  color:#000;
}

.ts-prev{ left:10px; }
.ts-next{ right:10px; }

.ts-arrow:hover{
  background:#d4ff3f;
}
@media(max-width:1024px){
.ts-slide {
    min-width: 100%;
    flex-shrink: 1;
}
.ts-quote{
    font-size:42px;
  }
    .ts-slide {
    min-width: 100%;
    flex-shrink: 1;
    padding: 30px 0;
  }
}
/* MOBILE */
@media(max-width:768px){

  .ts-quote{
    font-size:42px;
  }
  .ts-arrow{
    width:45px;
    height:45px;
  }
  .ts-slide {
    min-width: 100%;
    flex-shrink: 1;
    padding: 30px 0;
  }
  .ts-circle-wrap::after {
    content: "";
    position: absolute;
    width: 100%;
    height: 39%;
  }
  .ts-quote {
    font-size: 36px;
  }
  .ts-prev {
    left: 1px;
}
.ts-next {
    right: 1px;
}
.ts-adv {
    margin-top: 50px;
}
}

</style>

<script>
document.addEventListener("DOMContentLoaded", function(){

  const slider = document.getElementById("tsSlider");
  const slides = document.querySelectorAll(".ts-slide");
  const next = document.querySelector(".ts-next");
  const prev = document.querySelector(".ts-prev");

  let index = 0;
  const total = slides.length;

  function update(){
    slider.style.transform = "translateX(-" + (index * 100) + "%)";
  }

  next.addEventListener("click", ()=>{
    if(index < total - 1){
      index++;
      update();
    }
  });

  prev.addEventListener("click", ()=>{
    if(index > 0){
      index--;
      update();
    }
  });

});
</script>