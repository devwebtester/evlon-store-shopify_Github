<spot-services-{{ ai_gen_id }} class="ai-spot-services-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-spot-services-container-{{ ai_gen_id }}">
    <div class="ai-spot-services-grid-{{ ai_gen_id }}">
      <div class="ai-spot-services-left-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-spot-services-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}

        <ul class="ai-spot-services-list-{{ ai_gen_id }}">
          {% for i in (1..5) %}
            {% assign title_key = 'service_' | append: i | append: '_title' %}
            {% assign title = block.settings[title_key] %}

            {% if title != blank %}
              {% assign number = i %}
              {% if number < 10 %}
                {% assign number_display = '0' | append: number %}
              {% else %}
                {% assign number_display = number %}
              {% endif %}

              <li
                class="ai-spot-services-item-{{ ai_gen_id }} {% if i == 1 %}active{% endif %}"
                data-index="{{ i }}"
              >
                <div class="ai-spot-services-item-inner-{{ ai_gen_id }}">
                  <div class="ai-spot-services-item-content-{{ ai_gen_id }}">
                    <span class="ai-spot-services-number-{{ ai_gen_id }}">{{ number_display }}</span>
                    <h3 class="ai-spot-services-title-{{ ai_gen_id }}">{{ title }}</h3>
                  </div>
                  <div class="ai-spot-services-arrow-{{ ai_gen_id }}">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <line x1="5" y1="12" x2="19" y2="12"></line>
                      <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                  </div>
                </div>
              </li>
            {% endif %}
          {% endfor %}
        </ul>
      </div>

      <div class="ai-spot-services-right-{{ ai_gen_id }}">
        {% for i in (1..5) %}
          {% assign title_key = 'service_' | append: i | append: '_title' %}
          {% assign description_key = 'service_' | append: i | append: '_description' %}
          {% assign image_key = 'service_' | append: i | append: '_image' %}

          {% assign title = block.settings[title_key] %}
          {% assign description = block.settings[description_key] %}
          {% assign image = block.settings[image_key] %}

          {% if title != blank %}
            <div
              class="ai-spot-services-content-item-{{ ai_gen_id }} {% if i == 1 %}active{% endif %}"
              data-index="{{ i }}"
            >
              {% if description != blank %}
                <div class="ai-spot-services-description-{{ ai_gen_id }}">
                  {{ description }}
                </div>
              {% endif %}

              <div class="ai-spot-services-image-wrapper-{{ ai_gen_id }}">
                {% if image %}
                  <img
                    src="{{ image | image_url: width: 1000 }}"
                    alt="{{ image.alt | escape }}"
                    loading="lazy"
                    width="{{ image.width }}"
                    height="{{ image.height }}"
                    class="ai-spot-services-image-{{ ai_gen_id }}"
                  >
                {% else %}
                  <div class="ai-spot-services-image-placeholder-{{ ai_gen_id }}">
                    {{ 'image' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</spot-services-{{ ai_gen_id }}>

<script>
  (function() {
    class SpotServices{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.items = [];
        this.contentItems = [];
        this.currentIndex = null;
      }

      connectedCallback() {
        this.items = this.querySelectorAll('.ai-spot-services-item-{{ ai_gen_id }}');
        this.contentItems = this.querySelectorAll('.ai-spot-services-content-item-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.items.forEach((item) => {
          item.addEventListener('click', (e) => {
            const index = item.getAttribute('data-index');
            this.switchActive(index);
          });

          item.addEventListener('mouseenter', (e) => {
            const index = item.getAttribute('data-index');
            this.switchActive(index);
          });
        });
      }

      switchActive(index) {
        if (this.currentIndex === index) return;

        this.items.forEach((item) => {
          if (item.getAttribute('data-index') === index) {
            item.classList.add('active');
          } else {
            item.classList.remove('active');
          }
        });

        this.contentItems.forEach((content) => {
          if (content.getAttribute('data-index') === index) {
            content.classList.add('active');
          } else {
            content.classList.remove('active');
          }
        });

        this.currentIndex = index;
      }
    }

    customElements.define('spot-services-{{ ai_gen_id }}', SpotServices{{ ai_gen_id }});
  })();
</script>

