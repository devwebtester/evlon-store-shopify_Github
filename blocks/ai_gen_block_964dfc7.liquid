{% doc %}
  @prompt
    Create a Shopify section (Liquid + CSS + JavaScript in one file) with the following requirements:
    
    SECTION NAME: "Spot Services Interactive"
    
    LAYOUT:
    - Two column layout
    - Left side (40%) → heading + service list
    - Right side (60%) → dynamic image + description
    
    LEFT SIDE:
    - Large heading: "Global leader in construction & real estate"
    - Below heading create a vertical list of services (accordion style but NO dropdown content)
    - Each item should have:
      - Number (01, 02, 03…)
      - Title text
      - Circular arrow button on right side
    
    INTERACTION:
    - On hover OR click on any item:
      - That item becomes active
      - Arrow rotates or moves
      - Right side content updates (image + text)
    - Only one active item at a time
    - First item active by default
    
    RIGHT SIDE:
    - Dark background card
    - Top small description text
    - Below that a rounded image
    - Content changes dynamically based on active item
    
    ANIMATION:
    - Smooth fade transition for image + text
    - Active item highlight with color change
    - Arrow icon rotate or translate animation
    
    SHOPIFY REQUIREMENTS:
    - Use section schema
    - Each accordion item should be a block with:
      - title
      - description
      - image
    - Max 5 blocks
    - Fully customizable from Shopify editor
    
    STYLING:
    - Modern clean design
    - Large bold heading
    - Thin divider lines between items
    - Rounded image corners
    - Soft hover effects
    
    RESPONSIVE:
    - On mobile:
      - Stack layout
      - Accordion on top, image below
      - Same interaction works
    
    OUTPUT:
    - Provide full single Shopify section code
    - Include Liquid, CSS, and JavaScript in one file
    - No external libraries
    
    IMPORTANT:
    - This is NOT a traditional accordion
    - Do NOT show dropdown content
    - Only titles act as tabs to change right side content, Use data-index mapping between left items and right content. Use JS to switch active state.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-spot-services-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-spot-services-container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-spot-services-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    {% comment %} gap: 60px; {% endcomment %}
    align-items: start;
  }

  .ai-spot-services-left-{{ ai_gen_id }} {
    position: sticky;
    top: 100px;
    width:75%;
  }

  .ai-spot-services-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 700;
    line-height: 1.1;
    margin: 0 0 40px 0;
    color: {{ block.settings.heading_color }};
  }

  .ai-spot-services-list-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ai-spot-services-item-{{ ai_gen_id }} {
    border-bottom: 1px solid {{ block.settings.divider_color }};
    padding: 20px 0;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-spot-services-item-{{ ai_gen_id }}:first-child {
    border-top: 1px solid {{ block.settings.divider_color }};
  }

  .ai-spot-services-item-inner-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .ai-spot-services-item-content-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 20px;
    flex: 1;
  }

  .ai-spot-services-number-{{ ai_gen_id }} {
    font-size: 18px;
    font-weight: 600;
    color: {{ block.settings.number_color }};
    transition: opacity 0.3s ease;
  }

  .ai-spot-services-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.item_title_size }}px;
    font-weight: 700;
    color: {{ block.settings.item_title_color }};
    margin: 0;
    transition: color 0.3s ease;
  }

  .ai-spot-services-arrow-{{ ai_gen_id }} {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background-color: {{ block.settings.arrow_bg_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    flex-shrink: 0;
  }

  .ai-spot-services-arrow-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
    stroke: {{ block.settings.arrow_icon_color }};
    transition: transform 0.3s ease;
  }

  .ai-spot-services-item-{{ ai_gen_id }}.active .ai-spot-services-number-{{ ai_gen_id }} {
    opacity: 1;
  }

  .ai-spot-services-item-{{ ai_gen_id }}.active .ai-spot-services-title-{{ ai_gen_id }} {
    color: {{ block.settings.active_title_color }};
  }

  .ai-spot-services-item-{{ ai_gen_id }}.active .ai-spot-services-arrow-{{ ai_gen_id }} {
    background-color: {{ block.settings.active_arrow_bg_color }};
    transform: translateX(8px);
  }
.ai-spot-services-item-{{ ai_gen_id }}.active .ai-spot-services-item {
     border-bottom: 1px solid #000000;
  }
  .ai-spot-services-item-{{ ai_gen_id }}.active .ai-spot-services-arrow-{{ ai_gen_id }} svg {
    stroke: {{ block.settings.active_arrow_icon_color }};
    transform: rotate(-45deg);
  }

  .ai-spot-services-item-{{ ai_gen_id }}:hover .ai-spot-services-arrow-{{ ai_gen_id }} {
    background-color: {{ block.settings.hover_arrow_bg_color }};
  }

  .ai-spot-services-right-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_bg_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: 40px;
    min-height: 800px;
    position: relative;
  }

  .ai-spot-services-content-item-{{ ai_gen_id }} {
    position: absolute;
    top: 150px;
    left: 40px;
    right: 40px;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s ease, visibility 0.4s ease;
    pointer-events: none;
  }

  .ai-spot-services-content-item-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .ai-spot-services-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0 0 15px 0;
  }

  .ai-spot-services-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
  }

  .ai-spot-services-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-spot-services-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 4 / 3;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-spot-services-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
    opacity: 0.3;
  }
