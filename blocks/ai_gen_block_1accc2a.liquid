{% doc %}
  @prompt
    Create a Shopify section (Liquid + HTML + CSS + JavaScript) for a modern horizontal timeline with scroll animation.
    
    Design Requirements:
    - Match a premium minimalist design (light beige background #f5f3ef or similar)
    - Large bold heading: "40+ years of a remarkable journey"
    - Small rounded label above heading: "OUR STORY"
    - Timeline items displayed horizontally in a single row
    
    Timeline Content:
    - Each item includes:
      - Year (large, lime/yellow color #d6e34a, bold, behind or above image)
      - 3D-style building image (centered, floating with soft shadow)
      - Small circular dot connected to a thin horizontal line
      - Short description text below
    
    Example Years:
    1983, 1996, 2005, 2013, 2024
    
    Layout Behavior:
    - Horizontal timeline scrolls LEFT as user scrolls DOWN
    - Use smooth scroll animation (GSAP ScrollTrigger or pure JS)
    - Pin the section while scrolling (sticky effect)
    - When timeline reaches last item:
      - Unpin section
      - Continue normal vertical scroll to next section
    
    Animation:
    - Smooth easing
    - Slight parallax on images (optional)
    - Fade-in or scale-in for timeline items
    
    Extra UI:
    - Floating circular CTA button on right:
      "Get your free quote"
      Background same lime color
    
    Technical Requirements:
    - Must work as Shopify section (.liquid file)
    - Use schema for editable content (years, text, images)
    - Fully responsive:
      - Desktop: horizontal scroll
      - Mobile: stacked vertical timeline OR swipe scroll
    - Clean, modular CSS
    - No external dependencies except optional GSAP CDN
    
    Important:
    - Ensure scroll snapping feels smooth
    - No layout shift
    - Performance optimized
    
    Output:
    - Full Shopify section code
    - Include Liquid schema
    - Include JS inside script tags
    - Include CSS inside style tags
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-timeline-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    overflow: hidden;
    position: relative;
  }

  .ai-timeline-wrapper-{{ ai_gen_id }} {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-timeline-container-{{ ai_gen_id }} {
    width: 100%;
    max-width: 100%;
    position: relative;
  }

  .ai-timeline-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 60px;
    padding: 0 20px;
  }

  .ai-timeline-label-{{ ai_gen_id }} {
    display: inline-block;
    padding: 8px 20px;
    background-color: {{ block.settings.label_background }};
    color: {{ block.settings.label_text_color }};
    border-radius: 50px;
    font-size: {{ block.settings.label_font_size }}px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 20px;
  }

  .ai-timeline-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_font_size }}px;
    font-weight: 700;
    color: {{ block.settings.heading_color }};
    margin: 0;
    line-height: 1.2;
  }

  .ai-timeline-track-{{ ai_gen_id }} {
    position: relative;
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .ai-timeline-track-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-timeline-content-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.item_spacing }}px;
    padding: 40px 20px 60px;
    position: relative;
  }

  .ai-timeline-line-{{ ai_gen_id }} {
    position: absolute;
    bottom: 30px;
    left: 0;
    right: 0;
    height: 2px;
    background-color: {{ block.settings.line_color }};
    z-index: 1;
  }

  .ai-timeline-item-{{ ai_gen_id }} {
    flex: 0 0 auto;
    width: {{ block.settings.item_width }}px;
    position: relative;
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .ai-timeline-item-{{ ai_gen_id }}.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .ai-timeline-year-{{ ai_gen_id }} {
    font-size: {{ block.settings.year_font_size }}px;
    font-weight: 700;
    color: {{ block.settings.year_color }};
    margin-bottom: 20px;
    position: relative;
    z-index: 2;
  }

  .ai-timeline-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    margin-bottom: 30px;
    z-index: 2;
  }

  .ai-timeline-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease;
  }

  .ai-timeline-item-{{ ai_gen_id }}:hover .ai-timeline-image-{{ ai_gen_id }} {
    transform: translateY(-5px);
  }

  .ai-timeline-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    background-color: #e0e0e0;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .ai-timeline-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-timeline-dot-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    background-color: {{ block.settings.dot_color }};
    border-radius: 50%;
    position: absolute;
    bottom: -38px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    box-shadow: 0 0 0 4px {{ block.settings.background_color }};
  }

  .ai-timeline-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_font_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
    margin: 0;
  }

  .ai-timeline-cta-{{ ai_gen_id }} {
    position: fixed;
    bottom: 40px;
    right: 40px;
    z-index: 100;
  }

  .ai-timeline-cta-button-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    width: {{ block.settings.cta_size }}px;
    height: {{ block.settings.cta_size }}px;
    background-color: {{ block.settings.cta_background }};
    color: {{ block.settings.cta_text_color }};
    border-radius: 50%;
    text-decoration: none;
    font-size: {{ block.settings.cta_font_size }}px;
    font-weight: 600;
    text-align: center;
    padding: 20px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    line-height: 1.3;
  }

  .ai-timeline-cta-button-{{ ai_gen_id }}:hover {
    transform: scale(1.05);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.2);
  }

  @media screen and (max-width: 749px) {
    .ai-timeline-wrapper-{{ ai_gen_id }} {
      min-height: auto;
      padding: 60px 0;
    }

    .ai-timeline-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_font_size | times: 0.6 }}px;
    }

    .ai-timeline-header-{{ ai_gen_id }} {
      margin-bottom: 40px;
    }

    .ai-timeline-item-{{ ai_gen_id }} {
      width: {{ block.settings.item_width | times: 0.7 }}px;
    }

    .ai-timeline-year-{{ ai_gen_id }} {
      font-size: {{ block.settings.year_font_size | times: 0.7 }}px;
    }

    .ai-timeline-cta-{{ ai_gen_id }} {
      bottom: 20px;
      right: 20px;
    }

    .ai-timeline-cta-button-{{ ai_gen_id }} {
      width: {{ block.settings.cta_size | times: 0.8 }}px;
      height: {{ block.settings.cta_size | times: 0.8 }}px;
      font-size: {{ block.settings.cta_font_size | times: 0.8 }}px;
      padding: 15px;
    }
  }
{% endstyle %}

<horizontal-timeline-{{ ai_gen_id }} class="ai-timeline-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-timeline-wrapper-{{ ai_gen_id }}">
    <div class="ai-timeline-container-{{ ai_gen_id }}">
      {% if block.settings.show_header %}
        <div class="ai-timeline-header-{{ ai_gen_id }}">
          {% if block.settings.label != blank %}
            <div class="ai-timeline-label-{{ ai_gen_id }}">{{ block.settings.label }}</div>
          {% endif %}
          {% if block.settings.heading != blank %}
            <h2 class="ai-timeline-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
          {% endif %}
        </div>
      {% endif %}

      <div class="ai-timeline-track-{{ ai_gen_id }}" data-timeline-track>
        <div class="ai-timeline-content-{{ ai_gen_id }}">
          <div class="ai-timeline-line-{{ ai_gen_id }}"></div>

          {% for i in (1..5) %}
            {% liquid
              assign year_key = 'year_' | append: i
              assign image_key = 'image_' | append: i
              assign description_key = 'description_' | append: i

              assign year = block.settings[year_key]
              assign image = block.settings[image_key]
              assign description = block.settings[description_key]
            %}

            <div class="ai-timeline-item-{{ ai_gen_id }}" data-timeline-item>
              {% if year != blank %}
                <div class="ai-timeline-year-{{ ai_gen_id }}">{{ year }}</div>
              {% endif %}

              <div class="ai-timeline-image-wrapper-{{ ai_gen_id }}">
                {% if image %}
                  <img
                    src="{{ image | image_url: width: 600 }}"
                    alt="{{ year }}"
                    class="ai-timeline-image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="600"
                    height="600"
                  >
                {% else %}
                  <div class="ai-timeline-image-placeholder-{{ ai_gen_id }}">
                    {{ 'image' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>

              <div class="ai-timeline-dot-{{ ai_gen_id }}"></div>

              {% if description != blank %}
                <p class="ai-timeline-description-{{ ai_gen_id }}">{{ description }}</p>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>

  {% if block.settings.show_cta %}
    <div class="ai-timeline-cta-{{ ai_gen_id }}">
      <a href="{{ block.settings.cta_link }}" class="ai-timeline-cta-button-{{ ai_gen_id }}">
        {{ block.settings.cta_text }}
      </a>
    </div>
  {% endif %}
</horizontal-timeline-{{ ai_gen_id }}>

<script>
  (function() {
    class HorizontalTimeline{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.track = null;
        this.items = [];
        this.isScrolling = false;
        this.scrollTimeout = null;
      }

      connectedCallback() {
        this.track = this.querySelector('[data-timeline-track]');
        this.items = Array.from(this.querySelectorAll('[data-timeline-item]'));
        
        if (!this.track || this.items.length === 0) return;

        this.setupScrollAnimation();
        this.observeItems();
      }

      setupScrollAnimation() {
        let ticking = false;

        window.addEventListener('scroll', () => {
          if (!ticking) {
            window.requestAnimationFrame(() => {
              this.handleScroll();
              ticking = false;
            });
            ticking = true;
          }
        });

        this.track.addEventListener('scroll', () => {
          this.isScrolling = true;
          clearTimeout(this.scrollTimeout);
          this.scrollTimeout = setTimeout(() => {
            this.isScrolling = false;
          }, 150);
        });
      }

      handleScroll() {
        if (this.isScrolling) return;

        const rect = this.getBoundingClientRect();
        const windowHeight = window.innerHeight;
        const scrollProgress = Math.max(0, Math.min(1, (windowHeight - rect.top) / windowHeight));

        if (rect.top <= 0 && rect.bottom >= windowHeight) {
          const maxScroll = this.track.scrollWidth - this.track.clientWidth;
          const targetScroll = scrollProgress * maxScroll;
          
          this.track.scrollTo({
            left: targetScroll,
            behavior: 'auto'
          });
        }
      }

      observeItems() {
        const observerOptions = {
          root: this.track,
          threshold: 0.2,
          rootMargin: '0px'
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry, index) => {
            if (entry.isIntersecting) {
              setTimeout(() => {
                entry.target.classList.add('visible');
              }, index * 100);
            }
          });
        }, observerOptions);

        this.items.forEach(item => {
          observer.observe(item);
        });
      }
    }

    customElements.define('horizontal-timeline-{{ ai_gen_id }}', HorizontalTimeline{{ ai_gen_id }});
  })();
</script>

