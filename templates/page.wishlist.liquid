<div class="wishlist-page">
  <h1 class="wishlist-title">My Wishlist</h1>
  <div id="wishlist-container" class="wishlist-grid"></div>
</div>

<script>
function renderWishlist() {
  const container = document.getElementById('wishlist-container');
  const list = getWishlist();

  if (!list.length) {
    container.innerHTML = `<p class="empty">Your wishlist is empty</p>`;
    return;
  }

  container.innerHTML = list.map(item => `
    <div class="wishlist-card">
      
      <div class="wishlist-img">
        <img src="${item.image}" alt="${item.title}">
        <button class="remove-btn" data-id="${item.id}">×</button>
      </div>

      <div class="wishlist-info">
        <h3>${item.title}</h3>
        <div class="wishlist-actions">
          <a href="/products/${item.handle}" class="view-btn">View</a>
        </div>
      </div>

    </div>
  `).join('');
}

// REMOVE
document.addEventListener('click', function(e) {
  if (e.target.classList.contains('remove-btn')) {
    removeFromWishlist(e.target.dataset.id);
    renderWishlist();
    updateWishlistCount();
  }
});

document.addEventListener("DOMContentLoaded", renderWishlist);
</script>
<style>
    /* Page */
.wishlist-page {
  max-width: 1200px;
  margin: 40px auto;
  padding: 0 15px;
}

.wishlist-title {
  text-align: center;
  margin-bottom: 30px;
}

/* Grid */
.wishlist-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
  gap: 20px;
}

/* Card */
.wishlist-card {
  border: 1px solid #eee;
  border-radius: 10px;
  overflow: hidden;
  background: #fff;
  transition: 0.3s;
}

.wishlist-card:hover {
  box-shadow: 0 5px 15px rgba(0,0,0,0.1);
}

/* Image */
.wishlist-img {
  position: relative;
}

.wishlist-img img {
  width: 100%;
  display: block;
}

/* Remove button */
.remove-btn {
  position: absolute;
  top: 10px;
  right: 10px;
  background: red;
  color: #fff;
  border: none;
  width: 28px;
  height: 28px;
  border-radius: 50%;
  cursor: pointer;
  font-size: 16px;
}

/* Info */
.wishlist-info {
  padding: 15px;
  text-align: center;
}

.wishlist-info h3 {
  font-size: 16px;
  margin-bottom: 10px;
}

/* Buttons */
.view-btn {
  display: inline-block;
  padding: 8px 15px;
  background: black;
  color: #fff;
  text-decoration: none;
  border-radius: 5px;
  font-size: 14px;
}

/* Empty */
.empty {
  text-align: center;
  font-size: 18px;
  padding: 50px 0;
}
</style>